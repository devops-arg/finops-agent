# ============================================================
# FinOps Intelligence Platform — DevOps ARG
# Copy this file to .env and fill in your values
# ============================================================

# --- LLM Provider ---
# Options: "anthropic" (recommended) or "openai"
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI alternative
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# --- Demo Mode: LocalStack (no real AWS needed) ---
# Set USE_LOCALSTACK=true to use simulated AWS data.
# Run: docker compose up localstack before starting the agent.
USE_LOCALSTACK=true
LOCALSTACK_URL=http://localhost:4566

# Feature flag: USE_MOCK_DATA controls /api/report, /api/infrastructure, /api/optimize.
# - true  => dashboard endpoints return generated mock data (fast, for demos)
# - false => dashboard endpoints hit live AWS describe-* / Cost Explorer APIs
# Default: true when USE_LOCALSTACK=true, false otherwise.
# USE_MOCK_DATA=false

# --- Real AWS Mode (USE_LOCALSTACK=false) ---
# Choose ONE of the three options below. They are evaluated in this order:
#   A → B → C (role can combine with A or B as the source identity)
#
# Option A: Static access keys (recommended for CI / Docker)
#   Run: bash create-read-only.sh <your-admin-profile>  to generate these automatically.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# Regions to analyze for waste detection (comma-separated). Defaults to AWS_DEFAULT_REGION.
# AWS_REGIONS_TO_ANALYZE=us-east-1,us-east-2,eu-west-1

# Option B: Named AWS CLI profile (uses ~/.aws/credentials — good for local dev)
# AWS_PROFILE=finops

# Option C: Assume an existing IAM Role (works on top of A or B, or EC2/ECS instance role)
#   The app will call sts:AssumeRole at startup and use temporary credentials.
#   Useful when you already have a read-only role in your account.
# AWS_ASSUME_ROLE_ARN=arn:aws:iam::123456789012:role/FinOpsAgentReadOnly

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Optional ---
# Number of weeks to include in cost reports (default: 4)
# REPORT_WEEKS=4

# How many hours before a new waste scan is triggered on startup (default: 12).
# Set to 0 to always re-scan every time the app restarts.
# WASTE_SCAN_TTL_HOURS=12

# Tag keys to break down costs by in the Billing Insights tab (comma-separated).
# Set to the tag keys your team actually uses for environment/project/team tagging.
# Default: env. Example: env_aws,project,team
# COST_TAG_KEYS=env_aws,env
